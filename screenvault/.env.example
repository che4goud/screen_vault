# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=~/.screenvault/db.sqlite

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DIR=~/.screenvault

# ── Worker ────────────────────────────────────────────────────────────────────
MAX_WORKERS=5

# ── Backend ───────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ── Mac Agent ─────────────────────────────────────────────────────────────────
WATCH_DIR=~/Desktop
BACKEND_URL=http://localhost:8000
SCREENVAULT_USER_ID=          # set after Phase 3 auth is added
